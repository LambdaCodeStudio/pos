{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.medio AS \"medio: MedioPago\",\n               COALESCE(SUM(p.monto_centavos), 0)::bigint AS \"total!\"\n        FROM ventas.pagos p\n        JOIN ventas.ventas v ON v.id = p.venta_id\n        WHERE v.estado = 'confirmada'\n          AND (v.vendida_en AT TIME ZONE $3)::date BETWEEN $1 AND $2\n        GROUP BY p.medio\n        ORDER BY 2 DESC\n        ",
