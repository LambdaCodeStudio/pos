{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id, m.producto_id, p.nombre AS producto_nombre, m.lote_id, m.cantidad, m.creado_en\n        FROM inventario.movimientos_stock m\n        JOIN catalogo.productos p ON p.id = m.producto_id\n        WHERE m.ajuste_id = $1\n        ORDER BY m.creado_en\n        ",
