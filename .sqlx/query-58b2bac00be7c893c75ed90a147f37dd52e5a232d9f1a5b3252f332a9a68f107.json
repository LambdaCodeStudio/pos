{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, nombre, telefono, documento, limite_credito_centavos,\n               saldo_actual_centavos, activo\n        FROM clientes.clientes\n        WHERE (activo OR $1)\n          AND ($2::text IS NULL OR nombre ILIKE '%' || $2 || '%')\n          AND (NOT $3 OR saldo_actual_centavos <> 0)\n        ORDER BY nombre\n        LIMIT $4\n        ",
