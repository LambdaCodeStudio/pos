  "query": "\n        SELECT id, sesion_id, cliente_id, total_centavos, descuento_centavos,\n               estado AS \"estado: EstadoVenta\", usuario_id, vendida_en, sincronizada_en\n        FROM ventas.ventas\n        WHERE ($1::uuid IS NULL OR sesion_id = $1)\n        ORDER BY vendida_en DESC\n        LIMIT $2\n        ",
