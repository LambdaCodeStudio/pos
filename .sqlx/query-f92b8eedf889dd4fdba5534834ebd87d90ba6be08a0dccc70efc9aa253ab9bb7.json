  "query": "\n        SELECT r.estado AS \"estado: EstadoRecepcion\", p.precios_con_iva AS \"precios_con_iva?\"\n        FROM compras.recepciones r\n        LEFT JOIN compras.proveedores p ON p.id = r.proveedor_id\n        WHERE r.id = $1\n        FOR UPDATE OF r\n        ",
