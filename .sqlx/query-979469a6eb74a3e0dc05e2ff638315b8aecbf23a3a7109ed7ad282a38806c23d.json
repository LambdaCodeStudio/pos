  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.medio AS \"medio: MedioPago\", SUM(p.monto_centavos)::bigint AS \"total!\"\n        FROM ventas.pagos p\n        JOIN ventas.ventas v ON v.id = p.venta_id\n        WHERE v.sesion_id = $1 AND v.estado = 'confirmada'\n        GROUP BY p.medio\n        ",
